{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@eaos/contracts": ["backend/shared/contracts/src/index.ts"],
      "@eaos/events": ["backend/shared/events/src/index.ts"],
      "@eaos/pilot-core": ["backend/shared/pilot-core/src/index.ts"]
    },
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "dist"
  }
}

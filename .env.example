# EAOS development defaults (do not use in production)
DATABASE_URL=postgresql://eaos:eaos_password@localhost:5432/eaos
KAFKA_BROKERS=localhost:9092
REDIS_URL=redis://localhost:6379
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=eaos_access_key
OBJECT_STORAGE_SECRET_KEY=eaos_secret_key
POLICY_DECISION_MODE=enforce
RUNTIME_DEFAULT_NETWORK_PROFILE=none
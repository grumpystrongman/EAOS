# OpenAegis development defaults (do not use in production)
DATABASE_URL=postgresql://openaegis:change-me-local-postgres@localhost:5432/openaegis
KAFKA_BROKERS=localhost:9092
REDIS_URL=redis://localhost:6379
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=change-me-local-access-key
OBJECT_STORAGE_SECRET_KEY=change-me-local-secret-key
POLICY_DECISION_MODE=enforce
RUNTIME_DEFAULT_NETWORK_PROFILE=none

# GrumpyMan Distributors demo/company profile
OPENAEGIS_COMPANY_NAME=GrumpyMan Distributors
OPENAEGIS_COMPANY_DOMAIN=grumpyman-distributors.com
OPENAEGIS_TENANT_ID=tenant-grumpyman-distributors
OPENAEGIS_WORKFLOW_ID=wf-discharge-assistant
OPENAEGIS_PATIENT_ID=patient-1001
OPENAEGIS_USE_CASE_NAME=GrumpyMan Distributors Discharge Readiness Assistant

# Primary role logins
OPENAEGIS_CLINICIAN_EMAIL=clinician@grumpyman-distributors.com
OPENAEGIS_SECURITY_EMAIL=security@grumpyman-distributors.com
OPENAEGIS_ADMIN_EMAIL=admin@grumpyman-distributors.com
OPENAEGIS_PLATFORM_ADMIN_EMAIL=platform-admin@grumpyman-distributors.com
OPENAEGIS_SECURITY_ADMIN_EMAIL=security-admin@grumpyman-distributors.com
OPENAEGIS_AUDITOR_EMAIL=auditor@grumpyman-distributors.com
OPENAEGIS_WORKFLOW_OPERATOR_EMAIL=operator@grumpyman-distributors.com
OPENAEGIS_APPROVER_EMAIL=approver@grumpyman-distributors.com
OPENAEGIS_ANALYST_EMAIL=analyst@grumpyman-distributors.com

# Commercial connection seed defaults
OPENAEGIS_CONNECTIONS_TOOL_REGISTRY_PORT=4301
OPENAEGIS_CONNECTION_REF_PREFIX=vault://grumpyman-distributors/commercial
OPENAEGIS_BROKER_REF_PREFIX=broker://grumpyman-distributors/commercial
OPENAEGIS_COMMERCIAL_BASE_DOMAIN=enterprise.grumpyman-distributors.com
SANDBOX_SECOPS_REDPANDA_KAFKA_PORT=29092
SANDBOX_SECOPS_REDPANDA_ADMIN_PORT=29644

# OpenClaw local gateway configuration
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=change-me-openclaw-token

# Manus MCP configuration
MANUS_MCP_API_BASE_URL=https://api.manus.ai/v1
MANUS_MCP_API_KEY=change-me-manus-api-key

# Frontend build-time mirrors
VITE_OPENAEGIS_COMPANY_NAME=GrumpyMan Distributors
VITE_OPENAEGIS_TENANT_ID=tenant-grumpyman-distributors
VITE_OPENAEGIS_CLINICIAN_EMAIL=clinician@grumpyman-distributors.com
VITE_OPENAEGIS_SECURITY_EMAIL=security@grumpyman-distributors.com
VITE_OPENAEGIS_ADMIN_EMAIL=platform-admin@grumpyman-distributors.com
VITE_API_URL=http://127.0.0.1:3000
VITE_TOOL_REGISTRY_URL=http://127.0.0.1:4301
VITE_ENABLE_DEMO_IDENTITIES=true
